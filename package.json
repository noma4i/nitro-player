{
  "name": "@noma4i/nitro-play",
  "version": "2.0.0-beta.1",
  "description": "Lightweight video player for React Native",
  "author": "Alexander Tsirel",
  "license": "MIT",
  "homepage": "https://github.com/noma4i/nitro-player",
  "repository": {
    "type": "git",
    "url": "https://github.com/noma4i/nitro-player.git"
  },
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "react-native": "./lib/module/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "nitrogen",
    "nitro.json",
    "*.podspec",
    "react-native.config.js",
    "LICENSE",
    "!ios/build",
    "!android/build",
    "!**/__tests__",
    "!**/.*",
    "!**/CLAUDE.md"
  ],
  "scripts": {
    "nitrogen": "nitrogen .",
    "codegen:nitro": "yarn nitrogen",
    "codegen": "yarn codegen:nitro",
    "build": "yarn codegen && bob build",
    "release:notes": "node ./scripts/release-notes.mjs",
    "prepublishOnly": "yarn build && yarn test && yarn typecheck",
    "typecheck": "tsc --noEmit",
    "verify": "yarn test && yarn typecheck",
    "verify:example": "yarn --cwd example tsc --noEmit && yarn --cwd example test --runInBand --watchAll=false && yarn --cwd example android:build && yarn --cwd example ios:build",
    "verify:release": "yarn build && yarn verify && yarn verify:example",
    "test": "yarn audit:architecture && yarn audit:native-architecture && yarn test:behavior:audit && yarn audit:lifecycle && yarn test:ts && yarn test:android && yarn test:ios",
    "audit:architecture": "node ./scripts/audit-architecture.mjs",
    "audit:native-architecture": "node ./scripts/audit-native-architecture.mjs --self-test && node ./scripts/audit-native-architecture.mjs",
    "test:behavior:audit": "node ./scripts/check-behavior-tests.mjs",
    "audit:lifecycle": "node ./scripts/audit-lifecycle-guards.mjs --self-test && node ./scripts/audit-lifecycle-guards.mjs",
    "test:ts": "jest --runInBand",
    "test:android": "cd example/android && ./gradlew :noma4i_nitro-play:test",
    "test:ios": "cd tests/ios && swift test",
    "test:ios:tsan": "cd tests/ios && swift test --sanitize=thread",
    "test:ios:asan": "cd tests/ios && swift test --sanitize=address"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.0.10",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "nitrogen": "^0.35.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.40.0",
    "react-native-nitro-modules": "^0.35.2",
    "ts-jest": "^29.2.5",
    "typescript": "^5.2.2"
  },
  "packageManager": "yarn@4.9.2",
  "publishConfig": {
    "access": "public"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNCNitroPlayerViewSpec",
    "type": "components",
    "jsSrcsDir": "src/bridge/fabric",
    "android": {
      "javaPackageName": "com.nitroplay.video.bridge"
    },
    "ios": {
      "componentProvider": {
        "RNCNitroPlayerView": "RCTNitroPlayerComponentView"
      }
    }
  }
}
