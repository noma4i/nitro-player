{
  "name": "NitroPlayExample",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:build": "cd android && ./gradlew assembleDebug",
    "android:clean": "rm -rf android/app/.cxx android/app/build android/.gradle android/build",
    "android:device": "d=$(adb devices -l | grep 'usb:' | awk '{print $1}'); adb -s $d reverse --remove tcp:8081 2>/dev/null || true; adb -s $d reverse tcp:8081 tcp:8081 && react-native run-android",
    "android:emulator": "$ANDROID_HOME/emulator/emulator -avd Pixel_4a -no-snapshot-load & sleep 20 && react-native run-android",
    "ios": "react-native run-ios",
    "ios:build": "xcodebuild -workspace ios/NitroPlayExample.xcworkspace -scheme NitroPlayExample -configuration Debug -destination 'platform=iOS Simulator,name=iPhone 16 Pro,OS=18.5' build",
    "ios:tunnel": "iproxy 8081 8081",
    "ios:device": "react-native run-ios --device",
    "lint": "eslint .",
    "metro:start": "watchman watch-del-all && react-native start --reset-cache",
    "postinstall": "patch-package",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@noma4i/nitro-play": "portal:..",
    "@react-native/new-app-screen": "0.83.4",
    "@react-native/virtualized-lists": "0.83.4",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.4",
    "@react-native/eslint-config": "0.83.4",
    "@react-native/metro-config": "0.83.4",
    "@react-native/typescript-config": "0.83.4",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.9.2"
}
